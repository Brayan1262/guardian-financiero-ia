if [ -z "$MAVEN_SKIP_RC" ] ; then
  if [ -f /etc/mavenrc ] ; then
    . /etc/mavenrc
  fi
  if [ -f "$HOME/.mavenrc" ] ; then
    . "$HOME/.mavenrc"
  fi
fi

if [ -z "$JAVA_HOME" ] ; then
  JAVACMD=`which java`
else
  JAVACMD="$JAVA_HOME/bin/java"
fi

if [ ! -x "$JAVACMD" ] ; then
  echo "The JAVA_HOME environment variable is not defined correctly" >&2
  echo "This environment variable is needed to run this program" >&2
  echo "NB: JAVA_HOME should point to a JDK not a JRE" >&2
  exit 1
fi

BASE_DIR="$( cd "$( dirname "$0" )" && pwd )"

if [ -e "$BASE_DIR/.mvn/jvm.config" ]; then
  jvmconfig=`cat "$BASE_DIR/.mvn/jvm.config" | tr '\n' ' ' | tr '\r' ' ' | sed -e 's/^ *//' -e 's/ *$//'`
  MAVEN_OPTS="$MAVEN_OPTS $jvmconfig"
fi

WRAPPER_JAR="$BASE_DIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_LAUNCHER="org.apache.maven.wrapper.MavenWrapperMain"

DOWNLOAD_URL="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.2.0/maven-wrapper-3.2.0.jar"
WRAPPER_PROPERTIES="$BASE_DIR/.mvn/wrapper/maven-wrapper.properties"
if [ -f "$WRAPPER_PROPERTIES" ]; then
  wrapperUrl=$(grep '^wrapperUrl=' "$WRAPPER_PROPERTIES" | cut -d'=' -f2)
  if [ -n "$wrapperUrl" ]; then
    DOWNLOAD_URL="$wrapperUrl"
  fi
fi

if [ ! -e "$WRAPPER_JAR" ]; then
  if [ -n "$MVNW_VERBOSE" ]; then
    echo "Couldn't find $WRAPPER_JAR, downloading it ..."
    echo "Downloading from: $DOWNLOAD_URL"
  fi
  if command -v wget > /dev/null; then
    wget "$DOWNLOAD_URL" -O "$WRAPPER_JAR"
  elif command -v curl > /dev/null; then
    curl -o "$WRAPPER_JAR" "$DOWNLOAD_URL"
  else
    echo "No curl or wget found to download the wrapper jar" >&2
    exit 1
  fi
fi

export MAVEN_PROJECTBASEDIR="$BASE_DIR"
exec "$JAVACMD" \
  $MAVEN_OPTS \
  $MAVEN_DEBUG_OPTS \
  -classpath "$WRAPPER_JAR" \
  "-Dmaven.multiModuleProjectDirectory=$BASE_DIR" \
  $WRAPPER_LAUNCHER $MAVEN_CONFIG "$@"
